{
  "name": "@carrybot/core",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-agnostic brain: capture, distiller, brief. No DOM, no UI.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./capture": "./src/capture/index.ts",
    "./distiller": "./src/distiller/index.ts",
    "./brief": "./src/brief/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
